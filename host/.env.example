# Copy to .env and adjust. fader_mqtt_bridge.py auto-loads this file at startup
# (real environment variables win over it; CLI flags win over both).

# --- MQTT broker -----------------------------------------------------------
# IMPORTANT: this must be the broker your Home Assistant MQTT integration uses
# (HA > Settings > Devices & Services > MQTT > Configure). HA Discovery only
# reaches HA via *that* broker - it is often a different broker from other lab
# devices, and HA's bundled Mosquitto add-on is NOT anonymous (set auth below).
MQTT_BROKER=192.168.4.51
MQTT_PORT=1883

# Broker auth - required by HA's Mosquitto add-on (any HA user account works).
#MQTT_USERNAME=
#MQTT_PASSWORD=

# --- topic namespace / Home Assistant identity -----------------------------
# Root MQTT namespace and HA MQTT Discovery prefix. Defaults match the Knight
# Home Tech fader spec; only change MQTT_PREFIX to run a separate fleet.
MQTT_PREFIX=knighthometech
HA_DISCOVERY_PREFIX=homeassistant

# Friendly device name shown in Home Assistant (users can also rename in HA).
FADER_NAME=Knight Home Tech Fader

# Optional JSON file of device-id -> friendly name, e.g. {"a1b2c3":"Studio Fader"}.
#FADER_NAMES_FILE=

# --- behavior --------------------------------------------------------------
# Retain the last position so HA shows it immediately after a restart.
# Set to 0 for fresh-live-only (equivalent to --no-position-retain).
POSITION_RETAIN=1
