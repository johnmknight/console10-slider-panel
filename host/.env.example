# Copy to .env and adjust. The bridge reads these (env overrides built-in
# defaults; CLI flags override env).

# Lab broker on appserv1 (eclipse-mosquitto, anonymous on the LAN).
MQTT_BROKER=192.168.4.148
MQTT_PORT=1883

# Topic the slider value is published to (retained).
SLIDER_TOPIC=console10/slider/value

# Optional broker auth (leave unset for anonymous LAN access).
#MQTT_USERNAME=
#MQTT_PASSWORD=
